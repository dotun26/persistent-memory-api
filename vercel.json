{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/remember",
      "dest": "/api/remember.js",
      "methods": ["POST", "GET"]
    },
    {
      "src": "/api/search",
      "dest": "/api/search.js",
      "methods": ["GET"]
    }
  ]
}
