{
  "version": 2,
  "env": {
    "DATABASE_URL": "@database_url",
    "MEMORY_API_KEY": "@memory_api_key"
  },
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/remember",
      "dest": "/api/remember.js",
      "methods": ["POST", "GET"]
    },
    {
      "src": "/api/search",
      "dest": "/api/search.js",
      "methods": ["GET"]
    }
  ]
}
